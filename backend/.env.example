# ---- Server ----
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3000

# ---- Database (PostgreSQL) ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bda?schema=public

# ---- JWT ----
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- OTP ----
OTP_EXPIRY_MINUTES=5
OTP_RESEND_SECONDS=60

# ---- Email (Nodemailer / SMTP — Gmail / Google Workspace) ----
# Use a Google App Password (not your normal password): https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
MAIL_FROM_NAME="Bokaro Defence Academy"
# Must match SMTP_USER unless "Send mail as" is configured in Gmail
MAIL_FROM_ADDRESS=your_email@gmail.com

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=100

# ---- Uploads ----
UPLOAD_DIR=src/uploads
MAX_FILE_SIZE_MB=25
# Storage driver: "local" now, switch to "s3" later
STORAGE_DRIVER=local

# ---- Bcrypt ----
BCRYPT_SALT_ROUNDS=12

# ---- Razorpay (https://dashboard.razorpay.com → Settings → API Keys) ----
# Generate a NEW Key Id + Key Secret pair together (Test mode for local).
# Key Id starts with "rzp_test_" (test) or "rzp_live_" (live). Never mix modes.
# Never commit real keys.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Optional: only needed if you configure a Razorpay webhook
RAZORPAY_WEBHOOK_SECRET=

# ---- Super admin (created by seed) ----
SEED_SUPERADMIN_EMAIL=adminbokarodefenceacademy@gmail.com
SEED_SUPERADMIN_PASSWORD=Admin@12345
